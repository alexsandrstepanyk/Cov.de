# .env файл для WhatsApp Bot v4.0
# Скопіюйте цей файл як .env та заповніть своїми даними

# ============================================================================
# TWILIO WHATSAPP API
# ============================================================================

# Отримайте з Twilio Console: https://console.twilio.com/
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_auth_token_here

# WhatsApp номер (Sandbox для тестування)
TWILIO_WHATSAPP_NUMBER=whatsapp:+14155238886

# ============================================================================
# WEBHOOK НАЛАШТУВАННЯ
# ============================================================================

# Токен для перевірки вебхука
WEBHOOK_VERIFY_TOKEN=gov_de_2026

# Режим відладки (True/False)
FLASK_DEBUG=False

# ============================================================================
# БАЗА ДАНИХ
# ============================================================================

# Шлях до бази даних користувачів
DB_PATH=/Users/alex/Desktop/project/Gov.de/users.db

# ============================================================================
# ІНШІ НАЛАШТУВАННЯ
# ============================================================================

# Лог рівень (DEBUG, INFO, WARNING, ERROR)
LOG_LEVEL=INFO

# Шлях до лог файлу
LOG_FILE=/Users/alex/Desktop/project/Gov.de/logs/whatsapp_bot.log
