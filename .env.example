# ============================================================================
# TWILIO WHATSAPP API
# ============================================================================
# Отримати на: https://console.twilio.com/

# Account SID (формат: ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxx)
TWILIO_ACCOUNT_SID=your_twilio_account_sid_here

# Auth Token (32 символи)
TWILIO_AUTH_TOKEN=your_twilio_auth_token_here

# WhatsApp номер (Sandbox для тестування: whatsapp:+14155238886)
TWILIO_WHATSAPP_NUMBER=whatsapp:+14155238886

# ============================================================================
# TELEGRAM BOT API
# ============================================================================
# Отримати у @BotFather: https://t.me/botfather

# Токен Telegram бота (формат: xxxxxxxxxxx:xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx)
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here

# ============================================================================
# WEBHOOK НАЛАШТУВАННЯ
# ============================================================================

# Токен для перевірки вебхука (мінімум 16 символів)
WEBHOOK_VERIFY_TOKEN=your_secure_webhook_token_here

# Режим відладки (True/False)
FLASK_DEBUG=False

# ============================================================================
# БАЗА ДАНИХ
# ============================================================================

# Шлях до бази даних
DATABASE_PATH=./data/legal_database.db

# ChromaDB шлях
CHROMA_DB_PATH=./data/chroma_db

# ============================================================================
# LLM НАЛАШТУВАННЯ
# ============================================================================

# Ollama URL
OLLAMA_BASE_URL=http://localhost:11434

# Модель за замовчуванням (gemma:7b, gemma:2b, llama3.2, etc.)
DEFAULT_LLM_MODEL=gemma:7b

# ============================================================================
# ЛОГУВАННЯ
# ============================================================================

# Лог рівень (DEBUG, INFO, WARNING, ERROR, CRITICAL)
LOG_LEVEL=INFO

# Шлях до лог файлу
LOG_FILE=./logs/bot.log

# ============================================================================
# ПРОДУКТИВНІСТЬ
# ============================================================================

# Розмір кешу (кількість запитів)
CACHE_SIZE=1000

# Час життя кешу (секунди)
CACHE_TTL=3600

# ============================================================================
# ОБМЕЖЕННЯ
# ============================================================================

# Максимальний розмір файлу (MB)
MAX_FILE_SIZE_MB=10

# Максимальна кількість сторінок документа
MAX_DOCUMENT_PAGES=10
