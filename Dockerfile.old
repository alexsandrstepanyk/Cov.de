# Gov.de Bot Docker Image
# Німецький юридичний бот з OCR, перекладом та повною інтеграцією
# Версія: v4.0 Full Integration

FROM python:3.11-slim

# Мітки
LABEL maintainer="Oleksandr Stepaniuk"
LABEL version="4.0-full"
LABEL description="German Legal Document Analyzer Bot - Full Integration"

# Змінні оточення
ENV PYTHONUNBUFFERED=1 \
    PYTHONDONTWRITEBYTECODE=1 \
    PIP_NO_CACHE_DIR=1 \
    PIP_DISABLE_PIP_VERSION_CHECK=1 \
    DEBIAN_FRONTEND=noninteractive \
    PYTHONPATH=/app/src

# Робоча директорія
WORKDIR /app

# Встановлення системних залежностей
# Tesseract OCR, Poppler (PDF), Git, та інші необхідні бібліотеки
RUN apt-get update && apt-get install -y --no-install-recommends \
    # Tesseract OCR
    tesseract-ocr \
    tesseract-ocr-deu \
    tesseract-ocr-eng \
    tesseract-ocr-ukr \
    tesseract-ocr-rus \
    libtesseract-dev \
    libleptonica-dev \
    # PDF обробка
    poppler-utils \
    # Графічні бібліотеки для OpenCV/PIL
    libgl1 \
    libglib2.0-0 \
    libsm6 \
    libxext6 \
    libxrender-dev \
    libgomp1 \
    # Інструменти
    git \
    curl \
    && rm -rf /var/lib/apt/lists/* \
    && apt-get clean

# Копіюємо requirements.txt спочатку для кешування
COPY requirements.txt .

# Встановлення Python залежностей
RUN pip install --upgrade pip wheel && \
    pip install --no-cache-dir setuptools && \
    pip install --no-cache-dir -r requirements.txt && \
    # Додаткові залежності для повної функціональності
    pip install --no-cache-dir \
        googletrans==4.0.0-rc1 \
        python-telegram-bot[job-queue]>=20.0

# Копіюємо весь код проекту
COPY src/ ./src/

# Створюємо директорії для даних, логів, завантажень
RUN mkdir -p /app/data \
             /app/logs \
             /app/uploads \
             /app/test_letters \
             /app/users_db && \
    chmod -R 755 /app

# Встановлюємо права доступу для користувача (не root)
RUN useradd -m -u 1000 botuser && \
    chown -R botuser:botuser /app

# Переходимо на користувача (не root)
USER botuser

# Порт для Flask (якщо використовується вебхук)
EXPOSE 5000

# Health check - перевірка що бот працює
HEALTHCHECK --interval=30s --timeout=10s --start-period=60s --retries=3 \
    CMD python -c "import sys; sys.path.insert(0, '/app/src'); from advanced_ocr import recognize_image; from advanced_translator import translate_text_async; from legal_database import analyze_letter; print('All modules OK')" || exit 1

# Команда запуску - використовуємо повну версію бота
CMD ["python", "src/bots/client_bot_v4_full.py"]

# Альтернатива: старий бот (якщо потрібно)
# CMD ["python", "src/bots/client_bot.py"]
